{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "timezone": "Asia/Shanghai",
  "schedule": [
    "before 9am on monday"
  ],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Group non-major Composer updates",
      "matchManagers": [
        "composer"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "composer non-major dependencies"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions"
    },
    {
      "description": "Require separate PRs for major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": null
    }
  ]
}